@model ACBarberShop.Application.DTOs.FacturaDTO

@{
    ViewData["Title"] = "Details";
}

<style>
    .factura-section {
        margin-bottom: 30px;
    }

        .factura-section h4 {
            margin-bottom: 20px;
        }

        .factura-section hr {
            margin-top: 0;
            margin-bottom: 20px;
        }

        .factura-section dl,
        .factura-section table {
            width: 100%;
        }

            .factura-section dl dt {
                font-weight: bold;
            }

    .factura-header {
        display: flex;
        justify-content: space-between;
    }

        .factura-header dl {
            width: 48%;
        }

    .table th, .table td {
        vertical-align: middle;
        text-align: right;
    }

        .table th:first-child, .table td:first-child {
            text-align: left;
        }

        .table th:nth-child(2), .table td:nth-child(2) {
            text-align: left;
        }

    .totals-row dt {
        text-align: right;
        font-weight: bold;
        font-size: 1.2em;
    }

    .totals-row dd {
        text-align: right;
        font-weight: bold;
        font-size: 1.2em;
    }

    .total-highlight {
        font-weight: bold;
        font-size: 1.2em;
        color: #000;
    }

    .highlight {
        font-weight: bold;
        font-size: 1.2em;
        color: #000;
    }

    h1 {
        font-weight: bold;
        color: #000;
    }

    .main-container {
        margin-top: 40px;
    }

    .card {
        border: 1px solid #ddd;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        padding: 20px;
        background-color: #fff;
    }

    .back-button {
        margin-top: 20px;
    }

    .btn-primary {
        background-color: #000;
        border-color: #007bff;
        color: white;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 5px;
    }

        .btn-primary:hover {
            background-color: #424242;
            border-color: #004085;
        }
</style>

<div class="main-container">
    <div class="card">
        <h1>Detalles de la Factura</h1>

        <div class="factura-section">
            <hr />
            <div class="factura-header">
                <dl class="row">
                    <dt class="col-sm-4 highlight">Fecha</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Fecha)</dd>
                </dl>
                <dl class="row">
                    <dt class="col-sm-4 highlight">Cliente</dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.IdCliente) - @Html.DisplayFor(model => model.Nombre)
                    </dd>
                </dl>
            </div>
            <dl class="row">
                <dt class="col-sm-2 highlight">Sucursal</dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.IdSucursalNavigation.Nombre)<br />
                    Tel: @Html.DisplayFor(model => model.IdSucursalNavigation.Telefono)<br />
                    Dirección: @Html.DisplayFor(model => model.IdSucursalNavigation.IdDireccionNavigation.DireccionExacta)<br />
                    Correo: @Html.DisplayFor(model => model.IdSucursalNavigation.CorreoElectronico)
                </dd>
            </dl>
        </div>

        <div class="factura-section">
            <hr />
            <table class="table">
                <thead>
                    <tr>
                        <th>Producto/Servicio</th>
                        <th>Detalle</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.FacturaServicio)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.IdServicioNavigation.Nombre)</td>
                            <td>@Html.DisplayFor(modelItem => item.IdServicioNavigation.Descripcion)</td>
                            <td>₡@Html.DisplayFor(modelItem => item.IdServicioNavigation.Tarifa)</td>
                            <td>@Html.DisplayFor(modelItem => item.Cantidad)</td>
                            <td>₡@Html.DisplayFor(modelItem => item.SubTotal)</td>
                        </tr>
                    }
                    @foreach (var item in Model.FacturaProducto)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.IdProductoNavigation.Nombre)</td>
                            <td>@Html.DisplayFor(modelItem => item.IdProductoNavigation.Descripcion)</td>
                            <td>₡@Html.DisplayFor(modelItem => item.IdProductoNavigation.Precio)</td>
                            <td>@Html.DisplayFor(modelItem => item.Cantidad)</td>
                            <td>₡@Html.DisplayFor(modelItem => item.SubTotal)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="factura-section">
            <hr />
            <dl class="row totals-row">
                <dt class="col-sm-10 total-highlight">Total de la Compra</dt>
                <dd class="col-sm-2 total-highlight">₡@Html.DisplayFor(model => model.Total)</dd>
            </dl>
        </div>

    </div>

    <div class="back-button">
        <a asp-action="Index" class="btn btn-primary">Volver al Listado</a>
    </div>
</div>