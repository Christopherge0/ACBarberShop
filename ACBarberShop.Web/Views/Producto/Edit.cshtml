@model ACBarberShop.Application.DTOs.ProductoDTO

@{
    ViewData["Title"] = "Edit";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h1 class="card-title text-center mb-1">Editar Producto</h1>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group mb-3">
                            <label asp-for="IdProducto" class="control-label"></label>
                            <input asp-for="IdProducto" class="form-control" readonly />
                            <span asp-validation-for="IdProducto" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Nombre" class="control-label">Nombre del Producto:</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Descripcion" class="control-label">Descripción:</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="IdCategoria" class="control-label">Categoría:</label>
                            <label asp-for="IdCategoria" class="form-label"></label>
                            @Html.DropDownListFor(m => m.IdCategoria,
                                     new SelectList(ViewBag.ListaCategoria, "IdCategoria", "Nombre"),
                                     new { @class = "form-select" })
                            <span asp-validation-for="IdCategoria" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Precio" class="control-label">Precio (₡):</label>
                            @{
                                // Formatear el precio sin decimales
                                string formatearPrecio = string.Format("{0:F0}", Model.Precio);
                            }
                            <input asp-for="Precio" class="form-control" type="number" step="1" value="@formatearPrecio" />
                            <span asp-validation-for="Precio" class="text-danger"></span>
                        </div>


                        <div class="form-group mb-3">
                            <label asp-for="Volumen" class="control-label">Volumen (ml):</label>
                            <input asp-for="Volumen" class="form-control" />
                            <small class="form-text text-muted">La medida del volumen está en mililitros (ml).</small>
                            <span asp-validation-for="Volumen" class="text-danger"></span>
                        </div>



                        <div class="form-group mb-3">
                            <label asp-for="Marca" class="control-label">Marca:</label>
                            <input asp-for="Marca" class="form-control" />
                            <span asp-validation-for="Marca" class="text-danger"></span>
                        </div>

                        <div class="form-group text-center">
                            <button type="submit" class="btn btn-primary">Guardar Producto</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-3">
    <a asp-action="IndexAdmin" class="btn btn-secondary">Regresar</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
