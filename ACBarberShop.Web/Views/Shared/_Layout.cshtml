<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ACBarberShop.Web</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="~/css/bootstrap-lux.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* <link rel="stylesheet" href="~/ACBarberShop.Web.styles.css" asp-append-version="true" /> *@

    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
        }

        footer {
            width: 100%;
            position: fixed;
            bottom: 0;
            background-color: #171718; /* Same as navbar color */
            border-top: 1px solid #dee2e6;
            padding: 10px 0;
            text-align: center;
            color: white; /* Text color to ensure readability */
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="/Home">AC BARBERSHOP</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarColor01">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link active" href="/Home">
                                Inicio
                                <span class="visually-hidden">(current)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Producto">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Servicio">Servicios</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Factura">Facturacion</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Cita">Reservacion</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">Mantenimientos</a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="/Producto/IndexAdmin">Producto</a>
                                <a class="dropdown-item" href="/Servicio/IndexAdmin">Servicio</a>
                                <a class="dropdown-item" href="/Sucursal">Sucursal</a>
                                <a class="dropdown-item" href="#">Citas</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">Separated link</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2024 - ACBarberShop.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: white;">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>