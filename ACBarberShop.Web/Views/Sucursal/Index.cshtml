@model IEnumerable<ACBarberShop.Application.DTOs.SucursalDTO>

@{
    ViewData["Title"] = "Lista de Sucursales";
}

<div class="container mt-4">
    <h1 class="text-center">@ViewData["Title"]</h1>
    <p>
        <a href="@Url.Action("Create")" class="btn btn-secondary btn-sm create-button">Agregar Sucursal</a>
    </p>
    <div class="table-responsive">
        <table class="table table-striped table-bordered text-center">
            <thead class="thead-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.IdSucursal)</th>
                    <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.Telefono)</th>
                    <th>@Html.DisplayNameFor(model => model.IdDireccion)</th>
                    <th>@Html.DisplayNameFor(model => model.CorreoElectronico)</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.IdSucursal)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.Telefono)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.IdDireccionNavigation.DireccionExacta)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.CorreoElectronico)</td>
                        <td class="align-middle">
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("Details", new { id = item.IdSucursal })" class="btn btn-secondary btn-sm details-button">Detalles</a>
                                <a href="@Url.Action("Edit", new { id = item.IdSucursal })" class="btn btn-secondary btn-sm edit-button">Editar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .container {
        margin-top: 20px; 
    }

    h1 {
        margin-bottom: 20px; 
    }

    .create-button {
        margin-bottom: 20px; 
        background-color: transparent; 
        border:none; 
        color: #000; 
        transition: background-color 0.3s ease, color 0.3s ease; 
    }

        .create-button:hover {
            background-color: #6c757d;
            color: #fff;
        }

    .table-responsive {
        overflow-x: auto; 
    }

    .table {
        min-width: 800px;
    }

    .btn-group {
        display: flex; 
    }

    .details-button, .edit-button {
        margin-right: 5px; 
        background-color: transparent; 
        border:none; 
        color: #000;
        transition: background-color 0.3s ease, color 0.3s ease; 
    }

        .details-button:hover, .edit-button:hover {
            color: #fff; 
            background-color: #6c757d;
        }
</style>
